---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SoftwareCard from '../../components/SoftwareCard.astro';
import { categories, categoryMap } from '../../data/categories';
import { software } from '../../lib/software';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const items = software.filter((item) => item.category === category.slug);
---

<BaseLayout title={`${category.name} - 免费软件导航`} description={category.description}>
  <section class="bg-white">
    <div class="container-page py-10">
      <p class="mb-3 text-sm font-semibold text-brand-700">软件分类</p>
      <h1 class="text-3xl font-bold text-slate-950">{category.name}</h1>
      <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">{category.description}</p>
    </div>
  </section>
  <section class="container-page py-10">
    {items.length > 0 ? (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((item) => <SoftwareCard item={item} />)}
      </div>
    ) : (
      <div class="card p-8 text-center">
        <h2 class="text-lg font-semibold text-slate-950">该分类暂未收录软件</h2>
        <p class="mt-2 text-sm text-slate-600">你可以在数据文件中添加软件并设置 category 为 {category.slug}。</p>
      </div>
    )}
  </section>
</BaseLayout>
