---
import BaseLayout from '../layouts/BaseLayout.astro';
import SoftwareCard from '../components/SoftwareCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PortalList from '../components/PortalList.astro';
import SidebarBlock from '../components/SidebarBlock.astro';
import { categories } from '../data/categories';
import { software, sortByUpdatedAt } from '../lib/software';
import { sitePath } from '../lib/paths';

const hotSoftware = software.filter((item) => item.isHot).slice(0, 4);
const latestSoftware = sortByUpdatedAt(software).slice(0, 6);
const recommendedSoftware = software.filter((item) => item.isRecommended).slice(0, 6);
const latestLongList = sortByUpdatedAt(software).slice(0, 9);
---

<BaseLayout title="免费软件导航 - 正版软件与开源工具资源库" description="收录正版免费软件、开源软件、官方软件下载入口和软件使用教程的中文资源导航站。">
  <section class="border-b border-slate-200 bg-white">
    <div class="container-page py-8">
      <div class="grid gap-6 lg:grid-cols-[1fr_320px] lg:items-center">
        <div>
          <h1 class="text-3xl font-bold text-slate-950 sm:text-4xl">免费软件资源分享站</h1>
          <p class="mt-3 text-base leading-7 text-slate-600">每天整理正版免费软件、开源工具、官方入口和实用教程，帮你少走弯路，远离下载站套路。</p>
        </div>
        <a href={sitePath('/about')} class="rounded-lg border border-blue-100 bg-blue-50 p-4 text-sm leading-6 text-blue-900 hover:border-blue-200">
          <strong>本站原则</strong><br />
          只收录官方、免费、开源与合法分发入口。
        </a>
      </div>

      <div class="mt-7 rounded-lg border border-slate-200 bg-slate-50 p-4">
        <div class="mb-3 flex flex-wrap gap-2 text-sm">
          {['站内', 'Windows', 'Mac', 'AI 工具', '开源'].map((label) => <span class="rounded-md bg-white px-3 py-1 font-medium text-slate-600">{label}</span>)}
        </div>
        <form action={sitePath('/search')} class="flex flex-col gap-3 sm:flex-row">
          <input name="q" type="search" placeholder="站内搜索：Everything、录屏、开源、AI、办公效率..." class="min-h-12 flex-1 rounded-md border border-slate-300 bg-white px-4 text-base outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-100" />
          <button class="button-primary min-h-12 px-6" type="submit">搜索</button>
        </form>
      </div>

      <div class="mt-5 grid gap-4 md:grid-cols-2">
        <a href={sitePath('/category/windows')} class="card p-5 hover:border-brand-200">
          <p class="text-sm font-semibold text-brand-700">装机必备</p>
          <h2 class="mt-2 text-xl font-bold text-slate-950">Windows 免费工具合集</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">文件搜索、系统增强、效率启动器、安全工具。</p>
        </a>
        <a href={sitePath('/category/free-alternatives')} class="card p-5 hover:border-brand-200">
          <p class="text-sm font-semibold text-brand-700">免费替代</p>
          <h2 class="mt-2 text-xl font-bold text-slate-950">常用商业软件替代方案</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">优先推荐开源、免费、官方可持续使用的选择。</p>
        </a>
      </div>
    </div>
  </section>

  <section class="container-page grid gap-8 py-10 lg:grid-cols-[1fr_330px]">
    <div class="space-y-8">
      <PortalList title="最新发布" items={latestLongList} />
      <section>
        <SectionHeader eyebrow="最新软件" title="软件分享" href={sitePath('/search')} linkText="更多+" />
        <div class="grid gap-5 sm:grid-cols-2">
          {latestSoftware.slice(0, 4).map((item) => <SoftwareCard item={item} />)}
        </div>
      </section>
    </div>

    <aside class="space-y-6">
      <section class="card p-5">
        <h2 class="font-bold text-slate-950">分类导航</h2>
        <div class="mt-4 grid grid-cols-2 gap-2">
          {categories.slice(0, 10).map((category) => (
            <a href={sitePath(`/category/${category.slug}`)} class="rounded-md bg-slate-100 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-brand-50 hover:text-brand-700">{category.name}</a>
          ))}
        </div>
      </section>
      <SidebarBlock title="最新访问" items={hotSoftware.concat(latestSoftware).slice(0, 6)} />
      <SidebarBlock title="推荐软件" items={recommendedSoftware.slice(0, 6)} />
      <section class="rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
        <h2 class="font-bold">免责声明</h2>
        <p class="mt-2">本站不提供破解、激活码、盗版安装包。下载链接尽量指向官网、GitHub、应用商店或开发者页面。</p>
      </section>
    </aside>
  </section>

  <section class="container-page py-8">
    <SectionHeader eyebrow="热门软件" title="近期高频使用工具" description="优先展示适合大多数用户日常安装和长期使用的软件。" />
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {hotSoftware.map((item) => <SoftwareCard item={item} />)}
    </div>
  </section>

  <section class="container-page py-8">
    <SectionHeader eyebrow="推荐软件" title="值得优先尝试" description="从实用性、官方渠道清晰度、跨平台支持和长期维护情况综合挑选。" />
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {recommendedSoftware.map((item) => <SoftwareCard item={item} />)}
    </div>
  </section>
</BaseLayout>
