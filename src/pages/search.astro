---
import BaseLayout from '../layouts/BaseLayout.astro';
import { software } from '../lib/software';
import { categories } from '../data/categories';

const searchableSoftware = software.map((item) => ({
  ...item,
  categoryName: categories.find((category) => category.slug === item.category)?.name ?? item.category
}));
---

<BaseLayout title="搜索软件 - 免费软件导航" description="按软件名称、分类、标签和简介搜索正版免费软件、开源软件与官方软件下载入口。">
  <section class="bg-white">
    <div class="container-page py-10">
      <p class="mb-3 text-sm font-semibold text-brand-700">本地搜索</p>
      <h1 class="text-3xl font-bold text-slate-950">搜索软件</h1>
      <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">支持按软件名称、分类、标签和简介实时搜索，所有搜索都在浏览器本地完成。</p>
      <input id="search-input" type="search" placeholder="输入关键词，例如：录屏、AI、开源、Windows" class="mt-6 min-h-12 w-full rounded-lg border border-slate-300 bg-white px-4 text-base outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-100" />
    </div>
  </section>

  <section class="container-page py-10">
    <div id="result-count" class="mb-5 text-sm text-slate-600"></div>
    <div id="search-results" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3"></div>
  </section>

  <script>
    import Fuse from 'fuse.js';

    const software = JSON.parse(document.getElementById('software-data')?.textContent ?? '[]');
    const input = document.getElementById('search-input');
    const resultsEl = document.getElementById('search-results');
    const countEl = document.getElementById('result-count');
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') ?? '';

    const fuse = new Fuse(software, {
      threshold: 0.35,
      ignoreLocation: true,
      keys: ['name', 'categoryName', 'category', 'tags', 'description', 'platform', 'license']
    });

    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function card(item) {
      const tags = item.tags.slice(0, 3).map((tag) => `<span class="tag">${escapeHtml(tag)}</span>`).join('');
      return `
        <article class="card flex h-full flex-col p-5">
          <div class="mb-4 flex items-start gap-4">
            <img src="${escapeHtml(item.logo)}" alt="${escapeHtml(item.name)} 图标" class="size-12 rounded-lg border border-slate-200 bg-slate-50 p-2" loading="lazy" />
            <div class="min-w-0">
              <h2 class="truncate text-lg font-semibold text-slate-950"><a href="/software/${escapeHtml(item.slug)}" class="hover:text-brand-700">${escapeHtml(item.name)}</a></h2>
              <p class="mt-1 text-sm text-slate-500">${escapeHtml(item.categoryName)} · ${escapeHtml(item.license)}</p>
            </div>
          </div>
          <p class="line-clamp-3 flex-1 text-sm leading-6 text-slate-600">${escapeHtml(item.description)}</p>
          <div class="mt-4 flex flex-wrap gap-2">${tags}</div>
          <div class="mt-5 flex items-center justify-between gap-3">
            <a href="/software/${escapeHtml(item.slug)}" class="text-sm font-semibold text-brand-700 hover:text-brand-500">查看详情</a>
            <a href="${escapeHtml(item.officialUrl)}" target="_blank" rel="noopener noreferrer" class="button-secondary px-3 py-1.5">官网</a>
          </div>
        </article>
      `;
    }

    function render(query) {
      const trimmed = query.trim();
      const items = trimmed ? fuse.search(trimmed).map((result) => result.item) : software;
      resultsEl.innerHTML = items.map(card).join('');
      countEl.textContent = trimmed ? `找到 ${items.length} 个相关结果` : `共收录 ${items.length} 个软件`;
      const nextUrl = trimmed ? `/search?q=${encodeURIComponent(trimmed)}` : '/search';
      window.history.replaceState(null, '', nextUrl);
    }

    input.value = initialQuery;
    input.addEventListener('input', () => render(input.value));
    render(initialQuery);
  </script>
  <script id="software-data" type="application/json" set:html={JSON.stringify(searchableSoftware)} />
</BaseLayout>
