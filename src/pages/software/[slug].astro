---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SoftwareCard from '../../components/SoftwareCard.astro';
import { software, getAlternatives, getCategoryName } from '../../lib/software';
import { sitePath } from '../../lib/paths';

export function getStaticPaths() {
  return software.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const alternatives = getAlternatives(item);
const seoTitle = `${item.name} 官方下载与使用教程 - 免费软件导航`;
const seoDescription = `${item.name}：${item.description} 收录官方主页、官方下载地址、支持系统、软件特点和使用教程。`;
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <section class="bg-white">
    <div class="container-page grid gap-8 py-10 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
          <img src={sitePath(item.logo)} alt={`${item.name} 图标`} class="size-20 rounded-xl border border-slate-200 bg-slate-50 p-3" />
          <div>
            <p class="mb-2 text-sm font-semibold text-brand-700">{getCategoryName(item.category)}</p>
            <h1 class="text-3xl font-bold text-slate-950">{item.name}</h1>
            <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">{item.description}</p>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          <span class="tag">类型：{item.license}</span>
          {item.platform.map((platform) => <span class="tag">{platform}</span>)}
          {item.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
      <aside class="card p-5">
        <h2 class="text-base font-semibold text-slate-950">官方入口</h2>
        <div class="mt-4 grid gap-3">
          <a href={item.officialUrl} target="_blank" rel="noopener noreferrer" class="button-primary">官方网站</a>
          <a href={item.downloadUrl} target="_blank" rel="noopener noreferrer" class="button-secondary">官方下载</a>
          {item.githubUrl && <a href={item.githubUrl} target="_blank" rel="noopener noreferrer" class="button-secondary">GitHub 地址</a>}
        </div>
        <p class="mt-4 text-xs leading-5 text-slate-500">请优先通过官网、应用商店、GitHub Releases 或开发者页面下载。</p>
      </aside>
    </div>
  </section>

  <section class="container-page grid gap-8 py-10 lg:grid-cols-[1fr_320px]">
    <div class="grid gap-8">
      <section class="card p-6">
        <h2 class="text-xl font-bold text-slate-950">软件特点</h2>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {item.features.map((feature) => (
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm font-medium text-slate-700">{feature}</div>
          ))}
        </div>
      </section>

      <section class="card p-6">
        <h2 class="text-xl font-bold text-slate-950">适合人群</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          适合需要{item.tags.slice(0, 3).join('、')}相关能力，并希望通过正版、免费、开源或官方渠道获取软件的用户。
        </p>
      </section>

      <section class="card p-6">
        <h2 class="text-xl font-bold text-slate-950">使用教程</h2>
        <ol class="mt-5 grid gap-3">
          {item.tutorial.map((step, index) => (
            <li class="flex gap-3 rounded-lg bg-slate-50 p-4 text-sm leading-6 text-slate-700">
              <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-brand-600 text-xs font-bold text-white">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </section>

      <section class="card p-6">
        <h2 class="text-xl font-bold text-slate-950">免责声明</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">本站仅整理软件信息和官方入口，软件版权归原作者或所属公司所有。下载和使用前请阅读官方许可协议、隐私政策和系统要求。</p>
      </section>
    </div>

    <aside class="space-y-6">
      <div class="card p-5">
        <h2 class="text-base font-semibold text-slate-950">基础信息</h2>
        <dl class="mt-4 grid gap-3 text-sm">
          <div class="flex justify-between gap-4"><dt class="text-slate-500">支持系统</dt><dd class="text-right text-slate-700">{item.platform.join('、')}</dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">软件类型</dt><dd class="text-slate-700">{item.license}</dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">更新时间</dt><dd class="text-slate-700">{item.updatedAt}</dd></div>
        </dl>
      </div>
      <div class="card p-5">
        <h2 class="text-base font-semibold text-slate-950">类似软件推荐</h2>
        <div class="mt-4 grid gap-3">
          {alternatives.map((alternative) => (
            <a href={sitePath(`/software/${alternative.slug}`)} class="flex items-center gap-3 rounded-lg border border-slate-200 p-3 hover:border-brand-200">
              <img src={sitePath(alternative.logo)} alt={`${alternative.name} 图标`} class="size-9 rounded-md bg-slate-50 p-1.5" />
              <span class="text-sm font-semibold text-slate-800">{alternative.name}</span>
            </a>
          ))}
        </div>
      </div>
    </aside>
  </section>
</BaseLayout>
