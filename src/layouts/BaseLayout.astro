---
import '../styles.css';
import { sitePath } from '../lib/paths';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const navItems = [
  { href: sitePath('/'), label: '首页' },
  { href: sitePath('/category/windows'), label: 'Windows 必备' },
  { href: sitePath('/category/ai-tools'), label: 'AI 工具' },
  { href: sitePath('/search'), label: '搜索' },
  { href: sitePath('/about'), label: '关于本站' }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={sitePath('/favicon.svg')} type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
      <div class="container-page flex h-16 items-center justify-between gap-4">
        <a href={sitePath('/')} class="flex items-center gap-3 font-bold text-slate-950" aria-label="免费软件导航首页">
          <span class="flex size-9 items-center justify-center rounded-lg bg-brand-600 text-sm text-white">软</span>
          <span class="hidden sm:inline">免费软件导航</span>
        </a>
        <nav class="hidden items-center gap-1 md:flex">
          {navItems.map((item) => (
            <a href={item.href} class="rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-brand-700">
              {item.label}
            </a>
          ))}
        </nav>
        <a href={sitePath('/search')} class="button-primary">搜索软件</a>
      </div>
      <nav class="container-page flex gap-1 overflow-x-auto pb-3 md:hidden">
        {navItems.map((item) => (
          <a href={item.href} class="shrink-0 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-brand-700">
            {item.label}
          </a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mt-16 border-t border-slate-200 bg-white">
      <div class="container-page grid gap-6 py-10 md:grid-cols-[1.2fr_0.8fr_0.8fr]">
        <div>
          <div class="mb-3 flex items-center gap-3 font-bold">
            <span class="flex size-8 items-center justify-center rounded-lg bg-brand-600 text-xs text-white">软</span>
            免费软件导航
          </div>
          <p class="max-w-xl text-sm leading-6 text-slate-600">只收录正版免费软件、开源软件、官方软件下载入口与软件使用教程。不提供破解、激活码、补丁或盗版资源。</p>
        </div>
        <div>
          <h2 class="mb-3 text-sm font-semibold text-slate-900">站点页面</h2>
          <div class="grid gap-2 text-sm text-slate-600">
            <a href={sitePath('/about')} class="hover:text-brand-700">关于本站</a>
            <a href={sitePath('/disclaimer')} class="hover:text-brand-700">免责声明</a>
            <a href={sitePath('/search')} class="hover:text-brand-700">搜索软件</a>
          </div>
        </div>
        <div>
          <h2 class="mb-3 text-sm font-semibold text-slate-900">收录原则</h2>
          <p class="text-sm leading-6 text-slate-600">下载链接尽量指向官网、GitHub、Microsoft Store、开发者页面等官方渠道。</p>
        </div>
      </div>
    </footer>
  </body>
</html>
