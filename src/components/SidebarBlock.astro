---
import type { Software } from '../lib/software';
import { sitePath } from '../lib/paths';

interface Props {
  title: string;
  items: Software[];
}

const { title, items } = Astro.props;
---

<section class="card overflow-hidden">
  <div class="border-b border-slate-200 px-5 py-4">
    <h2 class="font-bold text-slate-950">{title}</h2>
  </div>
  <div class="divide-y divide-slate-100">
    {items.map((item) => (
      <a href={sitePath(`/software/${item.slug}`)} class="flex gap-3 px-5 py-4 hover:bg-slate-50">
        <img src={sitePath(item.logo)} alt={`${item.name} 图标`} class="size-10 rounded-lg border border-slate-200 bg-slate-50 p-2" loading="lazy" />
        <div class="min-w-0">
          <h3 class="line-clamp-2 text-sm font-semibold leading-5 text-slate-900">{item.name}</h3>
          <p class="mt-1 text-xs text-slate-500">{item.updatedAt}</p>
        </div>
      </a>
    ))}
  </div>
</section>
