---
import type { Software } from '../lib/software';
import { getCategoryName } from '../lib/software';

interface Props {
  item: Software;
}

const { item } = Astro.props;
---

<article class="card flex h-full flex-col p-5">
  <div class="mb-4 flex items-start gap-4">
    <img src={item.logo} alt={`${item.name} 图标`} class="size-12 rounded-lg border border-slate-200 bg-slate-50 p-2" loading="lazy" />
    <div class="min-w-0">
      <h3 class="truncate text-lg font-semibold text-slate-950">
        <a href={`/software/${item.slug}`} class="hover:text-brand-700">{item.name}</a>
      </h3>
      <p class="mt-1 text-sm text-slate-500">{getCategoryName(item.category)} · {item.license}</p>
    </div>
  </div>
  <p class="line-clamp-3 flex-1 text-sm leading-6 text-slate-600">{item.description}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {item.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <div class="mt-5 flex items-center justify-between gap-3">
    <a href={`/software/${item.slug}`} class="text-sm font-semibold text-brand-700 hover:text-brand-500">查看详情</a>
    <a href={item.officialUrl} target="_blank" rel="noopener noreferrer" class="button-secondary px-3 py-1.5">官网</a>
  </div>
</article>
