---
import type { Software } from '../lib/software';
import { getCategoryName } from '../lib/software';
import { sitePath } from '../lib/paths';

interface Props {
  title: string;
  items: Software[];
  moreHref?: string;
}

const { title, items, moreHref = sitePath('/search') } = Astro.props;
---

<section class="card overflow-hidden">
  <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
    <h2 class="text-lg font-bold text-slate-950">{title}</h2>
    <a href={moreHref} class="text-sm font-semibold text-brand-700 hover:text-brand-500">更多+</a>
  </div>
  <div class="divide-y divide-slate-100">
    {items.map((item, index) => (
      <article class="grid gap-4 px-5 py-5 sm:grid-cols-[92px_1fr]">
        <a href={sitePath(`/software/${item.slug}`)} class="flex size-20 items-center justify-center rounded-lg border border-slate-200 bg-slate-50">
          <img src={sitePath(item.logo)} alt={`${item.name} 图标`} class="size-12" loading="lazy" />
        </a>
        <div class="min-w-0">
          <div class="mb-2 flex flex-wrap gap-2">
            <a href={sitePath(`/category/${item.category}`)} class="tag">{getCategoryName(item.category)}</a>
            {item.isHot && <span class="tag bg-red-50 text-red-600">热门</span>}
            {index === 0 && <span class="tag bg-amber-50 text-amber-700">置顶</span>}
          </div>
          <h3 class="text-lg font-bold leading-7 text-slate-950">
            <a href={sitePath(`/software/${item.slug}`)} class="hover:text-brand-700">{item.name}：{item.description}</a>
          </h3>
          <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-600">{item.features.join('，')}</p>
          <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-slate-500">
            <span>{item.updatedAt}</span>
            <span>{item.platform.join(' / ')}</span>
            <span>{item.license}</span>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
