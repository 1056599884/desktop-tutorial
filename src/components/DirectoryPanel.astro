---
import { categories } from '../data/categories';
import type { Software } from '../lib/software';
import { getCategoryName } from '../lib/software';
import { sitePath } from '../lib/paths';

interface Props {
  items: Software[];
}

const { items } = Astro.props;
---

<section class="card overflow-hidden">
  <div class="border-b border-slate-200 bg-white px-5 py-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm text-slate-500">当前位置</p>
        <h2 class="mt-1 text-lg font-semibold text-slate-950">/ 正版软件资源库</h2>
      </div>
      <a href={sitePath('/search')} class="button-primary">搜索资源</a>
    </div>
  </div>

  <div class="divide-y divide-slate-100">
    {categories.map((category) => (
      <a href={sitePath(`/category/${category.slug}`)} class="group grid gap-3 px-5 py-4 hover:bg-slate-50 sm:grid-cols-[1fr_130px_130px] sm:items-center">
        <div class="flex min-w-0 items-center gap-3">
          <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-lg">📁</span>
          <div class="min-w-0">
            <h3 class="truncate font-semibold text-slate-900 group-hover:text-brand-700">{category.name}</h3>
            <p class="mt-1 line-clamp-1 text-sm text-slate-500">{category.description}</p>
          </div>
        </div>
        <span class="text-sm text-slate-500">{items.filter((item) => item.category === category.slug).length} 个资源</span>
        <span class="text-sm text-slate-400 sm:text-right">分类目录</span>
      </a>
    ))}

    {items.map((item) => (
      <div class="grid gap-3 px-5 py-4 hover:bg-slate-50 sm:grid-cols-[1fr_130px_130px] sm:items-center">
        <a href={sitePath(`/software/${item.slug}`)} class="flex min-w-0 items-center gap-3">
          <img src={sitePath(item.logo)} alt={`${item.name} 图标`} class="size-10 shrink-0 rounded-lg border border-slate-200 bg-white p-2" loading="lazy" />
          <div class="min-w-0">
            <h3 class="truncate font-semibold text-slate-900 hover:text-brand-700">{item.name}</h3>
            <p class="mt-1 line-clamp-1 text-sm text-slate-500">{item.description}</p>
          </div>
        </a>
        <span class="text-sm text-slate-500">{getCategoryName(item.category)}</span>
        <div class="flex gap-2 sm:justify-end">
          <a href={sitePath(`/software/${item.slug}`)} class="button-secondary px-3 py-1.5">详情</a>
          <a href={item.downloadUrl} target="_blank" rel="noopener noreferrer" class="button-primary px-3 py-1.5">下载</a>
        </div>
      </div>
    ))}
  </div>
</section>
