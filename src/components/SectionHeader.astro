---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  href?: string;
  linkText?: string;
}

const { eyebrow, title, description, href, linkText } = Astro.props;
---

<div class="mb-6 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
  <div>
    {eyebrow && <p class="mb-2 text-sm font-semibold text-brand-700">{eyebrow}</p>}
    <h2 class="text-2xl font-bold tracking-normal text-slate-950">{title}</h2>
    {description && <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">{description}</p>}
  </div>
  {href && linkText && <a href={href} class="text-sm font-semibold text-brand-700 hover:text-brand-500">{linkText}</a>}
</div>
